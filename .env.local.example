# .env.local.example — MicrobiomeOS

# ── LOKÁLNÍ VÝVOJ ──
# Databáze (lokální SQLite)
DATABASE_URL="file:./dev.db"

# DeepSeek API (pro AI zpracování studií)
DEEPSEEK_API_KEY="sk-..."

# NextAuth
NEXTAUTH_SECRET="generate-random-32-char-string"
NEXTAUTH_URL="http://localhost:3000"

# ── PRODUKCE (Vercel) ──
