# .env.local.example — MicrobiomeOS

# ── LOKÁLNÍ VÝVOJ ──
# Databáze (lokální SQLite)
DATABASE_URL="file:./dev.db"

# DeepSeek API (pro AI zpracování studií)
DEEPSEEK_API_KEY="sk-..."

# NextAuth
NEXTAUTH_SECRET="generate-random-32-char-string"
NEXTAUTH_URL="http://localhost:3000"

# ── PRODUKCE (Vercel) ──
# Na Vercelu v Settings → Environment Variables nastav:
#
# DATABASE_URL="postgresql://postgres:[HESLO]@db.ratledxmxenifgmxmank.supabase.co:6543/postgres?pgbouncer=true&connection_limit=1"
# DIRECT_URL="postgresql://postgres:[HESLO]@db.ratledxmxenifgmxmank.supabase.co:5432/postgres?sslmode=require"
# DEEPSEEK_API_KEY="sk-..."
# NEXTAUTH_SECRET="vygeneruj-nahodny-32-znakovy-retezec"
# NEXTAUTH_URL="https://tvoje-domena.vercel.app"
#
# DATABASE_URL = PgBouncer (port 6543) pro runtime dotazy — connection pooling
# DIRECT_URL   = Přímé spojení (port 5432) pro prisma db push — DDL operace
#
# Nepovinné:
# EMAIL_SERVER="smtp://user:pass@smtp.example.com:587"
# EMAIL_FROM="noreply@microbiomeos.app"
# GITHUB_ID="..."
# GITHUB_SECRET="..."
